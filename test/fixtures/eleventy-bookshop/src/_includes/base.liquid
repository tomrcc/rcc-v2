<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{{ title }}</title>
  </head>
  <body>
    <div data-rcc>
      <main data-rosey-root="{{ page.fileSlug | default: 'index' }}">
        {{ content }}
      </main>
    </div>
    <script>
      // RCC only runs inside CloudCannon's Visual Editor. On a Bookshop site it
      // also pauses/resumes Bookshop live editing across a locale switch (see
      // src/bookshop.ts) — a runtime path validated by hand via CHECKLIST.md.
      if (window.inEditorMode) {
        import("rosey-cloudcannon-connector");
      }
    </script>
  </body>
</html>
