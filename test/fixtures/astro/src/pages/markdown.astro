---
import Layout from "../layouts/Layout.astro";
---

<!--
  Intricate rendered markdown behind one data-rosey block: nested lists, a
  table, blockquote, code fence, inline code, link, and image. data-type="block"
  tells RCC/CloudCannon to open the markdown (block) editor rather than a plain
  text field — without it the entry is perpetually stale and uneditable. The
  full toolbar option set is configured in cloudcannon.config.yml (_editables);
  the Visual-Editor check confirms every button appears and that a round-trip
  edit produces no false stale.
-->
<Layout title="Markdown" roseyRoot="markdown">
  <article data-rosey="article" data-type="block">
    <h2>Rich content</h2>
    <p>A paragraph with <strong>bold</strong>, <em>italic</em>, and <code>inline code</code>.</p>

    <ul>
      <li>Top-level item
        <ol>
          <li>Nested ordered one</li>
          <li>Nested ordered two</li>
        </ol>
      </li>
      <li>Another top-level item</li>
    </ul>

    <blockquote>
      <p>A blockquote that should survive the round-trip unchanged.</p>
    </blockquote>

    <table>
      <thead>
        <tr><th>Locale</th><th>Direction</th></tr>
      </thead>
      <tbody>
        <tr><td>fr</td><td>ltr</td></tr>
        <tr><td>ar</td><td>rtl</td></tr>
      </tbody>
    </table>

    <pre><code>const greeting = "hello";
console.log(greeting);</code></pre>

    <p>A <a href="https://cloudcannon.com/">link</a> and an image:</p>
    <img src="/example.svg" alt="Example placeholder" width="48" height="48" />
  </article>
</Layout>
